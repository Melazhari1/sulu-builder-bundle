<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <!-- Admin: registers the navigation item, the view and the security context -->
        <service id="sulu_builder.admin" class="Xxp\SuluBuilderBundle\Admin\BuilderAdmin">
            <argument type="service" id="sulu_admin.view_builder_factory"/>
            <argument type="service" id="sulu_security.security_checker"/>

            <tag name="sulu.admin"/>
        </service>

        <!-- Domain service: reads/writes the XML template files -->
        <service id="sulu_builder.template_xml_manager" class="Xxp\SuluBuilderBundle\Service\TemplateXmlManager">
            <argument>%kernel.project_dir%</argument>
            <argument>%sulu_builder.template_directories%</argument>
        </service>

        <service id="Xxp\SuluBuilderBundle\Service\TemplateXmlManager" alias="sulu_builder.template_xml_manager"/>

        <!-- Admin API controller -->
        <service id="sulu_builder.template_controller" class="Xxp\SuluBuilderBundle\Controller\Admin\TemplateController" public="true">
            <argument type="service" id="sulu_builder.template_xml_manager"/>

            <tag name="controller.service_arguments"/>
        </service>

        <service id="Xxp\SuluBuilderBundle\Controller\Admin\TemplateController" alias="sulu_builder.template_controller" public="true"/>
    </services>
</container>
